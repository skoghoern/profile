---
interface Props {
  item: {
    title: string;
    description: string;
    journal: string;
    period: string;
    link: string;
  };
}

const { item } = Astro.props;
---

<article class="publication-card bg-accent/5 border border-accent/10 p-6 rounded-2xl hover:border-accent/40 transition-all group">
  <span class="font-mono text-xs tracking-widest uppercase text-accent/75">{item.period}</span>
  <h3 class="text-lg md:text-xl font-heading font-bold text-maintext mt-2 leading-snug">{item.title}</h3>
  <p class="text-accent text-sm mb-3 italic">{item.journal}</p>
  <p class="text-subtext font-body text-sm leading-relaxed mb-4">{item.description}</p>
  <a
    href={item.link}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 text-accent text-sm font-medium hover:underline"
  >
    View publication
    <span aria-hidden="true">→</span>
  </a>
</article>
