---
import { Icon } from 'astro-icon/components';
import localData from '../data/home.json';
import { resolveAssetImage } from '../utils/images';
import { Image } from 'astro:assets';

//Data Definitions
interface Social {
  name: string;
  url: string;
  icon: string;
}

interface ProfileData {
  name: string;
  photoUrl: string;
  intro: string;
  introHtml: string;
  resumeUrl: string;
  socials: Social[];
}

const isApiLive = import.meta.env.PROD; // Auto true in production
const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;

let data: ProfileData; // data as ProfileData

if (isApiLive && BASE_URL) {
  try {
    const response = await fetch(`${BASE_URL}/home`);
    if (!response.ok) throw new Error('Network response was not ok');
    data = await response.json();
  } catch (error) {
    console.error("API Fetch failed, falling back to mock data", error);
    data = localData as ProfileData;
  }
} else {
  data = localData as ProfileData;
}

const { name, photoUrl, intro, introHtml, resumeUrl, socials } = data;
const bioHtml = introHtml || intro;
const profileImage = await resolveAssetImage(photoUrl);
---

<section
  id="home"
  class="section-container md:pt-30 min-h-[80vh] flex items-center justify-center"
>
  <div
    class="w-full max-w-6xl mx-auto flex flex-col items-center gap-6 text-center
           lg:flex-row lg:items-center lg:justify-between lg:gap-16 lg:text-left"
  >
    <!-- Text column (left on wide screens) -->
    <div class="flex flex-col items-center gap-1 lg:items-start lg:flex-1 lg:min-w-0 order-2 lg:order-1">
      <div class="reveal-content" style="animation-delay: 200ms;">
        <p class="font-body font-light text-gray leading-relaxed">
          Hi, I'm
        </p>
      </div>

      <div class="px-6 sm:px-14 lg:px-0 max-w-2xl relative z-0 reveal-content" style="animation-delay: 300ms;">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-maintext tracking-tight">
          {name}
        </h1>
        <p
          class="mt-4 text-gray font-body text-lg leading-relaxed"
          set:html={bioHtml}
        />
      </div>

      {resumeUrl && resumeUrl !== "#" && (
        <div class="mt-6 reveal-content" style="animation-delay: 400ms;">
          <a
            href={resumeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative inline-flex items-center justify-center px-10 py-2 bg-white/5 border border-white/10 rounded-full text-maintext font-body transition-all duration-300 border-accent/50 bg-accent/10 shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)] lg:shadow-none lg:hover:border-accent/50 lg:hover:bg-accent/10 lg:hover:shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)] hover:scale-105"
          >
            <div class="flex flex-col items-center justify-center text-center">
              <span class="tracking-wide text-sm md:text-base font-medium transition-transform duration-300 lg:translate-y-2 lg:group-hover:translate-y-0">
                View Resume
              </span>
              <span class="text-[10px] text-subtext font-light whitespace-nowrap transition-all duration-300 opacity-100 translate-y-0 lg:opacity-0 lg:translate-y-1 lg:group-hover:opacity-100 lg:group-hover:translate-y-0">
                Downloads PDF file
              </span>
            </div>
            <div class="absolute inset-0 rounded-full blur-md bg-accent/20 -z-10 opacity-100 lg:opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500"></div>
          </a>
        </div>
      )}

      <div class="flex gap-6 mt-4 justify-center lg:justify-start reveal-content" style="animation-delay: 500ms;">
        {socials.filter((social) => social.url && social.url !== "#" && social.url !== "").map((social) => (
          <a
            href={social.url}
            target="_blank"
            class="group relative flex flex-col items-center justify-center transition-all duration-300 hover:scale-110"
          >
            <Icon
              name={social.icon}
              class="w-8 h-8 text-maintext group-hover:text-accent transition-colors duration-300"
            />
            <span class="absolute -bottom-6 scale-0 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-300 text-xs text-accent font-body">
              {social.name}
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Avatar column (right on wide screens) -->
    <div class="relative group mb-2 lg:mb-0 lg:shrink-0 order-1 lg:order-2 reveal-content" style="animation-delay: 100ms;">
      <div class="balloon-float w-20 h-20 md:w-24 md:h-24 lg:w-56 lg:h-56 xl:w-64 xl:h-64 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)]">
        {profileImage ? (
          <Image
            src={profileImage}
            alt={name}
            class="w-full h-full object-cover scale-110"
            loading="eager"
          />
        ) : (
          <img
            src={photoUrl || "/placeholder.jpeg"}
            alt={name}
            class="w-full h-full object-cover scale-110"
            onerror="this.onerror=null;this.src='/placeholder.jpeg';"
            loading="eager"
          />
        )}
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-20"></div>
    </div>
  </div>
</section>


<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* profile photo floating animation */

  /* When combined, the animation rule automatically merges these transforms */
  .avatar-container {
    animation: float 5s ease-in-out infinite alternate, wobble 7s ease-in-out infinite alternate;
  }

  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }

  @keyframes floating-balloon {
    0% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      /* Moves up and slightly right */
      transform: translate(3px, -8px) rotate(1deg);
    }
    66% {
      /* Drifts left and stays elevated */
      transform: translate(-3px, -4px) rotate(-1deg);
    }
    100% {
      /* Returns to start */
      transform: translate(0, 0) rotate(0deg);
    }
  }
</style>
